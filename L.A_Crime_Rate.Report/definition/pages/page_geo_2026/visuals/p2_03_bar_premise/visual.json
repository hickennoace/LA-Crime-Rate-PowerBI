{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.9.0/schema.json",
  "name": "p2_03_bar_premise",
  "position": {
    "x": 444,
    "y": 404,
    "z": 2000,
    "height": 292,
    "width": 540,
    "tabOrder": 3000
  },
  "visual": {
    "visualType": "barChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "crime"
                    }
                  },
                  "Property": "premise_description"
                }
              },
              "queryRef": "crime.premise_description",
              "nativeQueryRef": "premise_description",
              "active": true
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Total Crimes"
                }
              },
              "queryRef": "_Measures.Total Crimes",
              "nativeQueryRef": "Total Crimes"
            }
          ]
        }
      },
      "sortDefinition": {
        "sort": [
          {
            "field": {
              "Measure": {
                "Expression": {
                  "SourceRef": {
                    "Entity": "_Measures"
                  }
                },
                "Property": "Total Crimes"
              }
            },
            "direction": "Descending"
          }
        ],
        "isDefaultSort": true
      }
    },
    "visualContainerObjects": {
      "title": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            },
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'Top Premises (apply Top-N filter = 10 in Filters pane)'"
                }
              }
            }
          }
        }
      ]
    },
    "drillFilterOtherVisuals": true
  }
}