table DimDate
	lineageTag: a1b2c3d4-e5f6-4001-8001-100000000001

	column Date
		dataType: dateTime
		isKey
		formatString: Short Date
		lineageTag: a1b2c3d4-e5f6-4001-8001-100000000002
		dataCategory: PaddedDateTableDates
		summarizeBy: none
		isNameInferred
		sourceColumn: [Date]

		annotation SummarizationSetBy = Automatic

	column Year
		dataType: int64
		formatString: 0
		lineageTag: a1b2c3d4-e5f6-4001-8001-100000000003
		summarizeBy: none
		isNameInferred
		sourceColumn: [Year]

		annotation SummarizationSetBy = Automatic

	column 'Month No'
		dataType: int64
		formatString: 0
		lineageTag: a1b2c3d4-e5f6-4001-8001-100000000004
		summarizeBy: none
		isNameInferred
		sourceColumn: [Month No]

		annotation SummarizationSetBy = Automatic

	column 'Month Name'
		dataType: string
		lineageTag: a1b2c3d4-e5f6-4001-8001-100000000005
		summarizeBy: none
		isNameInferred
		sourceColumn: [Month Name]
		sortByColumn: 'Month No'

		annotation SummarizationSetBy = Automatic

	column YearMonth
		dataType: string
		lineageTag: a1b2c3d4-e5f6-4001-8001-100000000006
		summarizeBy: none
		isNameInferred
		sourceColumn: [YearMonth]

		annotation SummarizationSetBy = Automatic

	column Quarter
		dataType: string
		lineageTag: a1b2c3d4-e5f6-4001-8001-100000000007
		summarizeBy: none
		isNameInferred
		sourceColumn: [Quarter]

		annotation SummarizationSetBy = Automatic

	column 'Weekday No'
		dataType: int64
		formatString: 0
		lineageTag: a1b2c3d4-e5f6-4001-8001-100000000008
		summarizeBy: none
		isNameInferred
		sourceColumn: [Weekday No]

		annotation SummarizationSetBy = Automatic

	column 'Weekday Name'
		dataType: string
		lineageTag: a1b2c3d4-e5f6-4001-8001-100000000009
		summarizeBy: none
		isNameInferred
		sourceColumn: [Weekday Name]
		sortByColumn: 'Weekday No'

		annotation SummarizationSetBy = Automatic

	column IsPartialYear
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: a1b2c3d4-e5f6-4001-8001-10000000000a
		summarizeBy: none
		isNameInferred
		sourceColumn: [IsPartialYear]

		annotation SummarizationSetBy = Automatic

	partition DimDate = calculated
		mode: import
		source =
				ADDCOLUMNS (
				    CALENDAR ( DATE ( 2020, 1, 1 ), DATE ( 2023, 12, 31 ) ),
				    "Year",          YEAR ( [Date] ),
				    "Month No",      MONTH ( [Date] ),
				    "Month Name",    FORMAT ( [Date], "MMM" ),
				    "YearMonth",     FORMAT ( [Date], "YYYY-MM" ),
				    "Quarter",       "Q" & FORMAT ( [Date], "Q" ),
				    "Weekday No",    WEEKDAY ( [Date], 2 ),
				    "Weekday Name",  FORMAT ( [Date], "ddd" ),
				    "IsPartialYear", YEAR ( [Date] ) = 2023
				)

	annotation PBI_Id = a1b2c3d4e5f6400180010000000000ff

